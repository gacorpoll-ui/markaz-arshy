datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  Int                  @id @default(autoincrement())
  name                String
  email               String               @unique
  whatsapp            String?
  password            String?
  role                String               @default("USER") // USER, RESELLER, ADMIN
  isVerified          Boolean              @default(false)
  verificationToken   String?              @unique
  googleId            String?              @unique
  authProvider        String               @default("local") // local, google
  balance             Float                @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  orders              Order[]
  balanceTransactions BalanceTransaction[]
  deposits            Deposit[]            @relation("UserDeposits")
  confirmedDeposits   Deposit[]            @relation("AdminConfirmedDeposits")
  followers           Follower[]
  reviews             Review[]
  notifications       Notification[]
  aiApiKeys           AIApiKey[]
  aiUsages            AIUsage[]
  aiTransactions      AITransaction[]
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  type      String // SMM, PREMIUM
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id                Int       @id @default(autoincrement())
  categoryId        Int
  category          Category  @relation(fields: [categoryId], references: [id])
  name              String
  slug              String    @unique
  description       String?
  priceUser         Float
  priceReseller     Float
  type              String // SMM, PREMIUM
  providerServiceId String?
  minOrder          Int       @default(1)
  maxOrder          Int       @default(10000)
  isActive          Boolean   @default(true)
  providerStatus    String    @default("Tersedia")
  durationOptions   String? // JSON: [{"label":"1 Bulan","months":1,"priceMultiplier":1},...]
  osOptions         String? // JSON: ["Windows","Linux"] — khusus VPS/RDP
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  accounts          Account[]
  orders            Order[]
  reviews           Review[]
}

model Account {
  id           Int       @id @default(autoincrement())
  productId    Int
  product      Product   @relation(fields: [productId], references: [id])
  email        String
  password     String
  extraInfo    String?
  isSold       Boolean   @default(false)
  soldToUserId Int?
  soldAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  orders       Order[]
}

model Follower {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  platform       String
  username       String
  followerCount  Int      @default(0)
  targetFollower Int
  status         String   @default("ACTIVE")
  lastUpdated    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Order {
  id               Int      @id @default(autoincrement())
  userId           Int
  user             User     @relation(fields: [userId], references: [id])
  productId        Int
  product          Product  @relation(fields: [productId], references: [id])
  type             String
  targetUrl        String?
  quantity         Int?
  accountId        Int?
  account          Account? @relation(fields: [accountId], references: [id])
  amount           Float
  status           String   @default("PENDING")
  providerOrderId  String?
  providerStatus   String?
  notes            String?
  selectedDuration String? // "1 Bulan", "3 Bulan", dll.
  selectedOs       String? // "Windows", "Linux" — untuk VPS/RDP
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model BalanceTransaction {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  type          String
  amount        Float
  balanceBefore Float
  balanceAfter  Float
  description   String
  referenceId   String?
  createdAt     DateTime @default(now())
}

model PaymentMethod {
  id            Int       @id @default(autoincrement())
  name          String
  accountName   String
  accountNumber String
  instructions  String?
  qrImage       String? // BARU: URL gambar QRIS
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deposits      Deposit[]
}

model Deposit {
  id                Int            @id @default(autoincrement())
  userId            Int
  user              User           @relation("UserDeposits", fields: [userId], references: [id])
  amount            Float
  paymentMethod     String
  paymentMethodId   Int?
  paymentMethodRef  PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  paymentProof      String?
  midtransToken     String?
  status            String         @default("PENDING")
  confirmedByUserId Int?
  confirmedByUser   User?          @relation("AdminConfirmedDeposits", fields: [confirmedByUserId], references: [id])
  confirmedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model ProviderSetting {
  id        Int      @id @default(autoincrement())
  name      String
  apiUrl    String
  apiKey    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  productId  Int? // Opsional, jika review terkait produk tertentu
  product    Product? @relation(fields: [productId], references: [id])
  rating     Int      @default(5) // 1-5 stars
  comment    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  type      String // e.g., 'ORDER_STATUS', 'BALANCE_UPDATE', 'PROMOTION'
  message   String
  isRead    Boolean  @default(false)
  link      String? // Optional link for the notification
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════
// AI ROUTER MODELS
// ═══════════════════════════════════════════════════════════

model AIProvider {
  id          Int       @id @default(autoincrement())
  name        String    @unique // "OpenAI", "Anthropic", "Google AI"
  slug        String    @unique // "openai", "anthropic", "google-ai"
  description String?
  logoUrl     String?
  isActive    Boolean   @default(true)
  models      AIModel[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AIModel {
  id                  Int        @id @default(autoincrement())
  providerId          Int
  provider            AIProvider @relation(fields: [providerId], references: [id])
  name                String // "GPT-4o", "Claude 3.5 Sonnet"
  modelId             String     @unique // "gpt-4o", "claude-3-5-sonnet"
  inputPricePerToken  Float // Price per 1k input tokens
  outputPricePerToken Float // Price per 1k output tokens
  contextWindow       Int // Max tokens (e.g. 128000)
  isActive            Boolean    @default(true)
  apiKeys             AIApiKey[]
  usages              AIUsage[]
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
}

model AIApiKey {
  id             Int             @id @default(autoincrement())
  userId         Int
  user           User            @relation(fields: [userId], references: [id])
  modelId        Int? // Null = all models
  model          AIModel?        @relation(fields: [modelId], references: [id])
  keyName        String // User-defined name "My Dev Key"
  apiKey         String          @unique // Generated key "sk-mrkarsh-xxx"
  tier           String // "BASIC" | "PRO" | "ENTERPRISE"
  rateLimit      Int // Requests per minute
  monthlyQuota   Int? // Max tokens per month (null = unlimited)
  creditsBalance Float           @default(0) // Prepaid credits
  isActive       Boolean         @default(true)
  expiresAt      DateTime? // Null = no expiration
  lastUsedAt     DateTime?
  usages         AIUsage[]
  transactions   AITransaction[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model AIUsage {
  id           Int      @id @default(autoincrement())
  apiKeyId     Int
  apiKey       AIApiKey @relation(fields: [apiKeyId], references: [id])
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  modelId      Int
  model        AIModel  @relation(fields: [modelId], references: [id])
  requestId    String   @unique // From 9router webhook
  inputTokens  Int
  outputTokens Int
  totalTokens  Int
  inputCost    Float // Calculated cost
  outputCost   Float
  totalCost    Float
  endpoint     String // "/v1/chat/completions"
  statusCode   Int // 200, 429, 500
  latencyMs    Int // Response time in ms
  errorMessage String?
  metadata     String? // JSON: {model, temperature, etc}
  createdAt    DateTime @default(now())
}

model AITransaction {
  id             Int       @id @default(autoincrement())
  userId         Int
  user           User      @relation(fields: [userId], references: [id])
  apiKeyId       Int?
  apiKey         AIApiKey? @relation(fields: [apiKeyId], references: [id])
  amount         Float // +100 (top-up) or -0.05 (usage)
  type           String // "TOP_UP" | "USAGE" | "REFUND"
  description    String
  balanceBefore  Float
  balanceAfter   Float
  relatedUsageId Int?
  createdAt      DateTime  @default(now())
}
